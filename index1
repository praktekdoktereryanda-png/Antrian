<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<title>Sistem Antrian Klinik</title>

<style>
body {
    margin: 0;
    padding: 0;
    display: flex;
    height: 100vh;
    font-family: Arial, sans-serif;
    background: #000;
}

/* KIRI - IKLAN */
.left {
    width: 20%;
    background: #111;
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.left img {
    width: 90%;
    margin: 10px 0;
    border-radius: 10px;
}

/* TENGAH - VIDEO */
.center {
    width: 60%;
    display: flex;
    justify-content: center;
    align-items: center;
    background: black;
}

video {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* KANAN - ANTRIAN */
.right {
    width: 20%;
    background: #0d47a1;
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.antrian-box {
    text-align: center;
}

.antrian-title {
    font-size: 24px;
    margin-bottom: 10px;
}

.antrian-number {
    font-size: 100px;
    font-weight: bold;
}

.antrian-next {
    margin-top: 20px;
    font-size: 20px;
}
</style>
</head>

<body>

<!-- KIRI -->
<div class="left">
    <h3>Promo Klinik</h3>
    <img src="promo1.jpg">
    <img src="promo2.jpg">
</div>

<!-- TENGAH -->
<div class="center">
    <video id="videoPlayer" autoplay muted></video>
</div>

<!-- KANAN -->
<div class="right">
    <div class="antrian-box">
        <div class="antrian-title">Nomor Antrian</div>
        <div class="antrian-number" id="nomor">A001</div>
        <div class="antrian-next">Selanjutnya: <span id="next">A002</span></div>
    </div>
</div>

<script>
/* =========================
   PLAYLIST VIDEO AUTO LOOP
========================= */
const videos = [
    "video1.mp4",
    "video2.mp4",
    "video3.mp4"
];

let currentIndex = 0;
const player = document.getElementById("videoPlayer");

function playVideo(index) {
    player.src = videos[index];
    player.play();
}

player.addEventListener("ended", () => {
    currentIndex++;

    if (currentIndex >= videos.length) {
        currentIndex = 0; // balik ke awal
    }

    playVideo(currentIndex);
});

// mulai pertama
playVideo(currentIndex);


/* =========================
   SIMULASI ANTRIAN
========================= */
let nomor = 1;

function updateAntrian() {
    let current = "A" + String(nomor).padStart(3, '0');
    let next = "A" + String(nomor + 1).padStart(3, '0');

    document.getElementById("nomor").innerText = current;
    document.getElementById("next").innerText = next;

    nomor++;
}

// ganti nomor tiap 10 detik (simulasi)
setInterval(updateAntrian, 10000);
</script>

</body>
</html>